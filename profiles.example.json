{
  "profiles": {
    "example": {
      "host": "example.com",
      "port": 22,
      "user": "ubuntu",
      "key_path": "~/.ssh/id_rsa",
      "known_hosts_path": "~/.ssh/known_hosts",
      "strict_host_key_checking": true,
      "force_ipv4": false,
      "connect_timeout_sec": 15,
      "sudo_password_file": "~/.secrets/example_sudo_password",
      "auth_mode": "key",
      "aliases": ["prod", "production", "production server"],
      "default": true
    }
  },
  "audit": {
    "log_path": "~/.local/state/mcp-ssh-secure/audit.log"
  }
}
